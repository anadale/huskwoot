# config.toml.example — huskwoot configuration with push notifications via local relay.
# Copy to config/config.toml and fill in the values.

[user]
user_name        = "Your Name"
# aliases        = ["Nick"]
telegram_user_id = "${TELEGRAM_OWNER_ID}"

[ai.fast]
base_url = "https://api.openai.com/v1"
api_key  = "${OPENAI_API_KEY}"
model    = "gpt-4o-mini"

[ai.smart]
base_url = "https://api.openai.com/v1"
api_key  = "${OPENAI_API_KEY}"
model    = "gpt-4o"

[channels.telegram]
token    = "${TELEGRAM_BOT_TOKEN}"
# name   = "@myhuskwootbot"  # optional display name shown in pairing messages
on_join  = "monitor"
# reaction_enabled = true

[history]
max_messages = 200
ttl          = "24h"

[datetime]
timezone = "Europe/Moscow"
weekdays = ["mon", "tue", "wed", "thu", "fri"]

[datetime.time_of_day]
morning   = 11
lunch     = 12
afternoon = 14
evening   = 20

# HTTP API — required for the mobile app.
[api]
enabled              = true
listen_addr          = "0.0.0.0:8080"
external_base_url    = "https://server.example.org"
request_timeout      = "30s"
chat_timeout         = "60s"
events_retention     = "168h"
cors_allowed_origins = []
pairing_link_ttl            = "5m"
pairing_status_long_poll    = "60s"
rate_limit_pair_per_hour    = 5

# Push notifications via local push-relay.
# relay_url points to the internal Docker service — traffic stays within the VPS.
[push]
relay_url       = "http://push-relay:8080"
instance_id     = "main"
instance_secret = "${HUSKWOOT_PUSH_SECRET}"

# Scheduled summaries (optional).
#
# [reminders]
# plans_horizon   = "168h"
# undated_limit   = 5
# send_when_empty = "morning"
#
# [reminders.schedule]
# morning   = "09:00"
# afternoon = "14:00"
# evening   = "20:00"
